ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Autenticação da área interna do hub (proxy.ts protege / , /dashboard, /financeiro, /clientes, etc.)
# AUTH_PASSWORD: senha única de acesso. AUTH_SECRET: string aleatória usada para assinar o cookie de sessão.
AUTH_PASSWORD=choose_a_strong_password
AUTH_SECRET=random_long_secret_string
